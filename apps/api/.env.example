PORT=3000
HOST=127.0.0.1

# PostgreSQL connection string. Required in production and test.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bolt_everything

# Cookie settings
SESSION_COOKIE_NAME=bolt_session
# Must be at least 32 characters. Required in production.
SESSION_SECRET=change-me-to-a-long-random-secret-value

# Sign in with Apple — the services ID (bundle ID) registered in App Store Connect.
# Required in production.
APPLE_SERVICES_ID=com.example.bolt-everything

# Optional: comma-separated list of allowed CORS origins.
# Leave empty to disable CORS (recommended for mobile-only backend).
CORS_ORIGIN=
